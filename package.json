{
  "name": "influence-gate",
  "version": "0.0.1",
  "description": "",
  "author": "",
  "private": true,
  "license": "UNLICENSED",
  "scripts": {
    "build": "nest build",
    "format": "prettier --write \"src/**/*.ts\" \"test/**/*.ts\"",
    "start": "nest start",
    "start:dev": "nest start --watch",
    "start:debug": "nest start --debug --watch",
    "start:prod": "node dist/main",
    "lint": "eslint \"{src,apps,libs,test}/**/*.ts\" --fix",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:cov": "jest --coverage",
    "test:debug": "node --inspect-brk -r tsconfig-paths/register -r ts-node/register node_modules/.bin/jest --runInBand",
    "test:e2e": "jest --config ./test/jest-e2e.json",
    "seed:countries": "ts-node -r tsconfig-paths/register src/database/seeds/seed-countries.ts",
    "seed:admin": "ts-node -r tsconfig-paths/register src/database/seeds/seed-admin.ts",
    "seed:campaigns": "ts-node -r tsconfig-paths/register src/database/seeds/seed-campaigns.ts",
    "seed:wallet-transactions": "ts-node -r tsconfig-paths/register src/database/seeds/seed-wallet-transactions.ts",
    "seed:influencer-data": "ts-node -r tsconfig-paths/register src/database/seeds/seed-influencer-data.ts",
    "seed:open-campaigns": "ts-node -r tsconfig-paths/register src/database/seeds/seed-open-campaigns.ts",
    "seed:partial-indexes": "ts-node -r tsconfig-paths/register src/database/seeds/seed-partial-indexes.ts",
    "seed:contact-us": "ts-node -r tsconfig-paths/register src/database/seeds/seed-contact-us.ts",
    "seed:application-status-enum": "ts-node -r tsconfig-paths/register src/database/seeds/seed-application-status-enum.ts",
    "seed:hossam-campaigns": "ts-node -r tsconfig-paths/register src/database/seeds/seed-hossam-campaigns.ts",
    "seed:hossam-invitations": "ts-node -r tsconfig-paths/register src/database/seeds/seed-hossam-invitations.ts",
    "seed:hossam-private-invitations": "ts-node -r tsconfig-paths/register src/database/seeds/seed-hossam-private-invitations.ts",
    "seed:reset-hossam-pending-invitations": "ts-node -r tsconfig-paths/register src/database/seeds/reset-hossam-pending-invitations.ts",
    "seed:hossam-mixed-campaigns": "ts-node -r tsconfig-paths/register src/database/seeds/seed-hossam-mixed-campaigns.ts",
    "seed:hossam-public-campaigns": "ts-node -r tsconfig-paths/register src/database/seeds/seed-hossam-public-campaigns.ts",
    "seed:professional-campaigns": "ts-node -r tsconfig-paths/register src/database/seeds/seed-professional-campaigns.ts",
    "seed:platform-options": "ts-node -r tsconfig-paths/register src/database/seeds/seed-platform-options.ts",
    "seed:initial-data": "ts-node -r tsconfig-paths/register src/database/seeds/seed-initial-data.ts",
    "seed:advertiser-mock-reports": "ts-node -r tsconfig-paths/register src/database/seeds/seed-advertiser-mock-reports.ts",
    "migrate:enum-to-tables": "ts-node -r tsconfig-paths/register src/database/migrations/migrate-enum-to-tables.ts",
    "migrate:platforms-to-tables": "ts-node -r tsconfig-paths/register src/database/migrations/migrate-platforms-to-tables.ts",
    "db:clear": "ts-node -r tsconfig-paths/register src/clear-database.ts"
  },
  "dependencies": {
    "@nestjs/axios": "^4.0.1",
    "@nestjs/common": "^10.0.0",
    "@nestjs/config": "^4.0.3",
    "@nestjs/core": "^10.0.0",
    "@nestjs/jwt": "^11.0.2",
    "@nestjs/passport": "^11.0.5",
    "@nestjs/platform-express": "^10.0.0",
    "@nestjs/platform-socket.io": "^10.4.22",
    "@nestjs/schedule": "^6.1.1",
    "@nestjs/typeorm": "^11.0.0",
    "@nestjs/websockets": "^10.4.22",
    "@types/bcrypt": "^6.0.0",
    "@types/multer": "^2.1.0",
    "@types/passport-jwt": "^4.0.1",
    "axios": "^1.13.6",
    "bcrypt": "^6.0.0",
    "class-transformer": "^0.5.1",
    "class-validator": "^0.15.1",
    "cloudinary": "^2.9.0",
    "file-type": "^19.6.0",
    "firebase-admin": "^13.7.0",
    "ioredis": "^5.10.0",
    "multer": "^2.1.1",
    "passport": "^0.7.0",
    "passport-jwt": "^4.0.1",
    "pg": "^8.20.0",
    "reflect-metadata": "^0.2.0",
    "rxjs": "^7.8.1",
    "sib-api-v3-sdk": "^8.5.0",
    "socket.io": "^4.8.3",
    "typeorm": "^0.3.28"
  },
  "devDependencies": {
    "@nestjs/cli": "^10.0.0",
    "@nestjs/schematics": "^10.0.0",
    "@nestjs/testing": "^10.0.0",
    "@types/express": "^4.17.17",
    "@types/jest": "^29.5.2",
    "@types/node": "^20.3.1",
    "@types/streamifier": "^0.1.2",
    "@types/supertest": "^6.0.0",
    "@typescript-eslint/eslint-plugin": "^8.0.0",
    "@typescript-eslint/parser": "^8.0.0",
    "eslint": "^8.42.0",
    "eslint-config-prettier": "^9.0.0",
    "eslint-plugin-prettier": "^5.0.0",
    "jest": "^29.5.0",
    "prettier": "^3.0.0",
    "source-map-support": "^0.5.21",
    "streamifier": "^0.1.1",
    "supertest": "^7.0.0",
    "ts-jest": "^29.1.0",
    "ts-loader": "^9.4.3",
    "ts-node": "^10.9.1",
    "tsconfig-paths": "^4.2.0",
    "typescript": "^5.1.3"
  },
  "jest": {
    "moduleFileExtensions": [
      "js",
      "json",
      "ts"
    ],
    "rootDir": "src",
    "testRegex": ".*\\.spec\\.ts$",
    "transform": {
      "^.+\\.(t|j)s$": "ts-jest"
    },
    "collectCoverageFrom": [
      "**/*.(t|j)s"
    ],
    "coverageDirectory": "../coverage",
    "testEnvironment": "node"
  }
}
